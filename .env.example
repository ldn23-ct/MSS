# .env.example

# Geant4 installation
GEANT4_DIR=/path/to/geant4/install

# Build settings
BUILD_DIR=build
EXECUTABLE=MSS

# Runtime defaults
DEFAULT_MACRO=macros/run.mac
DEFAULT_MT_MACRO=macros/run_mt.mac
DEFAULT_THREADS=8
DEFAULT_RANDOM_SEED=12345

# Data paths
COLLIMATOR_PROFILE_FILE=data/collimator_profiles.csv
SPECTRUM_FILE=data/spectrum.csv

# Output
OUTPUT_DIR=results